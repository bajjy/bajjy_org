# bajjy.org environment

NODE_ENV=production

# port the Express server binds to (Coolify maps this to a public port)
PORT=3000

# GitHub username to surface on /projects
GITHUB_USERNAME=bajjy

# optional: a personal access token raises the GitHub API rate limit
# from 60 req/hour to 5000 req/hour. Read-only public scope is fine.
GITHUB_TOKEN=

# how long (seconds) to cache the GitHub repo list in memory
GITHUB_CACHE_TTL_SECONDS=900

# canonical site origin (used for og + canonical meta)
SITE_ORIGIN=https://bajjy.org
